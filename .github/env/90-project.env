# ================================================================================================
# 🏗️ PROJECT CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides and customizations
# Load Order: 90 (loaded after all default configurations, overrides previous settings)
#
# This file contains project-specific settings that override the defaults defined in
# earlier configuration files (00-core.env through 20-workflows.env).
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION
# ================================================================================================

# Project Go versions (overrides 00-core.env defaults)
GO_PRIMARY_VERSION=1.25.x
GO_SECONDARY_VERSION=1.25.x
MAGE_X_GO_SECONDARY_VERSION=1.25.x
MAGE_X_GO_VERSION=1.25.x

# ================================================================================================
# 📊 COVERAGE PROVIDER OVERRIDES
# ================================================================================================

# Use Codecov as the coverage provider (overrides 10-coverage.env default of 'internal')
GO_COVERAGE_PROVIDER=codecov

# Require Codecov token for uploads
CODECOV_TOKEN_REQUIRED=true

# ================================================================================================
# 🚫 COVERAGE EXCLUSIONS (matches codecov.yml ignore patterns)
# ================================================================================================

GO_COVERAGE_EXCLUDE_PATHS=.github/,.mage-cache/,.vscode/,bin/,example/,examples/,mocks/,testing/

# ================================================================================================
# 🛡️ VULNERABILITY SCANNING EXCLUSIONS
# ================================================================================================

# Custom exclusions for AskNancy vulnerability scanning
NANCY_EXCLUDES=CVE-2024-38513,CVE-2023-45142,CVE-2025-64702,CVE-2021-43668,CVE-2023-26248,CVE-2026-24051,CVE-2026-26014,CVE-2026-33186,CVE-2026-33809,CVE-2026-33813,CVE-2026-39882,CVE-2026-39883,CVE-2026-5160
MAGE_X_CVE_EXCLUDES=CVE-2024-38513,CVE-2023-45142,CVE-2025-64702,CVE-2021-43668,CVE-2023-26248,CVE-2026-24051,CVE-2026-26014,CVE-2026-33186,CVE-2026-33809,CVE-2026-33813,CVE-2026-39882,CVE-2026-39883,CVE-2026-5160
